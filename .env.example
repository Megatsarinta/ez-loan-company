# Copy to .env locally. On Vercel, set these in Project Settings → Environment Variables.
# Do not commit .env (it is gitignored).

# Database (Supabase / PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# Supabase
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# Optional: Supabase/Postgres (if your app reads these)
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=

# Admin (for admin login)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional
NODE_ENV=production
